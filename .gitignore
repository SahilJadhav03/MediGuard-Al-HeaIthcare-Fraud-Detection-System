frontend/dist/
frontend/.vite/
*.log
npm-debug.log*

# ── IDE / OS ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Kaggle credentials (NEVER commit) ─────────────────────────
kaggle.json
.kaggle/

